# CALC SECTION
def calculate_air_density(altitude):
    sea_level_density = 1.225
    return sea_level_density

def calc_aspect_ratio(wingspan, wing_area):
    return wingspan**2 / wing_area

def calc_induced_drag_factor(oswald, aspect_ratio):
    return 1 / (math.pi * oswald * aspect_ratio)

def calc_velocity(weight, rho, wing_area, CL):
    return (2 * weight / (rho * wing_area * CL)) ** 0.5

def calc_cd(cd0, k, CL):
    return cd0 + k * CL**2

def calc_lift(rho, velocity, wing_area, CL):
    return 0.5 * rho * velocity**2 * wing_area * CL

def calc_drag(rho, V, wing_area, CD):
    return 0.5 * rho * V**2 * wing_area * CD

def calc_LD(lift, drag):
    return lift / drag

# Performance Targets
def get_performance_targets(purpose):
    if purpose == "1":
        return {"LD": (30, 70), "speed": (20, 80)}
    
    elif purpose == "2":
        return {"LD": (15, 25), "speed": (150, 250)}
    
    elif purpose == "3":
        return {"LD": (5, 12), "speed": (200, 600)}
    
    elif purpose == "4":
        return {"LD": (15, 25), "speed": (200, 300)}
    
    elif purpose == "5":
        return {"LD": (8, 15), "speed": (50, 150)}
    
    else:
        return None

#Print the calculations dashboard
def generate_metric_dashboard(rho, aspect_ratio, k, V, CD, lift, drag, LD):
    return {
        "Air Density ": rho,
        "Aspect Ratio ": aspect_ratio,
        "Induced Drag Factor": k,
        "Velocity": V,
        "Coefficient of Drag": CD,
        "Lift": lift,
        "Drag": drag,
        "Lift to Drag Ratio": LD
    }

# TABLE
def display_dashboard(metric_dashboard):
    table = Table(title="[bold cyan not italic]\nMetrics[/bold cyan not italic]", title_justify="left")

    table.add_column("Metric", style="cyan")
    table.add_column("Value", style="magenta")

    for key, value in metric_dashboard.items():
        # handle numpy arrays safely
        if isinstance(value, np.ndarray):
            value = float(np.mean(value))

        table.add_row(key, f"{float(value):.2f}")

    print(table)

def score(purpose, LD, V):
    targets = get_performance_targets(str(purpose))
    
    if targets is None:
        print("Invalid aircraft purpose")
        return

    best_idx = np.argmax(LD)
    best_LD = LD[best_idx]
    best_V = V

    ld_min, ld_max = targets["LD"]
    sp_min, sp_max = targets["speed"]

    print("\n[bold cyan]Design Evaluation[/bold cyan]")
    print(f"L/D achieved: {best_LD:.2f}")
    print(f"Speed achieved: {best_V:.2f} m/s")

    # GOOD/BAD Design

    if purpose == 1:
        if ld_min <= best_LD <= ld_max and sp_min <= best_V <= sp_max:
            print("[bold green]Good design for Glider[/bold green]")
        else:
            print("[bold red]Poor design for Glider[/bold red]")

    elif purpose == 2:
        if ld_min <= best_LD <= ld_max and sp_min <= best_V <= sp_max:
            print("[bold green]Good design for Cargo Plane[/bold green]")
        else:
            print("[bold red]Poor design for Cargo Plane[/bold red]")

    elif purpose == 3:
        if ld_min <= best_LD <= ld_max and sp_min <= best_V <= sp_max:
            print("[bold green]Good design for Fighter Jet[/bold green]")
        else:
            print("[bold red]Poor design for Fighter Jet[/bold red]")

    elif purpose == 4:
        if ld_min <= best_LD <= ld_max and sp_min <= best_V <= sp_max:
            print("[bold green]Good design for Commercial Airliner[/bold green]")
        else:
            print("[bold red]Poor design for Commercial Airliner[/bold red]")

    elif purpose == 5:
        if ld_min <= best_LD <= ld_max and sp_min <= best_V <= sp_max:
            print("[bold green]Good design for General Aviation[/bold green]")
        else:
            print("[bold red]Poor design for General Aviation[/bold red]")

    else:
        print("Unknown aircraft type")

