# MAIN PROGRAM
def main():
    show_intro()

    wing_area = get_wing_area()
    wingspan = get_wingspan()
    weight = get_weight()
    engine_type = get_engine_type()
    altitude = get_altitude()
    V = get_velocity()
    purpose = get_aircraft_purpose()
    cd0 = get_cd0 ()
    oswald = get_oswald_efficiency()

    CL = give_cl_values()

    rho = calculate_air_density(altitude)
    aspect_ratio = calc_aspect_ratio(wingspan, wing_area)
    k = calc_induced_drag_factor(oswald, aspect_ratio)
    #V = calc_velocity(weight, rho, wing_area, CL)
    CD = calc_cd(cd0, k, CL)
    lift = calc_lift(rho, V, wing_area, CL)
    drag = calc_drag(rho, V, wing_area, CD)
    LD = calc_LD(lift, drag)

    metric_dashboard = generate_metric_dashboard(rho, aspect_ratio, k, V, CD, lift, drag, LD)

    #targets = get_performance_targets(purpose)
    results = score(purpose, LD, V)
    print(results)

    display_dashboard(metric_dashboard)
    #evaluate_design(purpose, dashboard)

# NESTED LOOP 
def run_simulation():
    while True:  # OUTER LOOP
        main()

        while True:  # INNER LOOP (validation)
            again = input("\nRun another simulation? (y/n): ").lower()
            if again in ["y", "n"]:
                break
            else:
                print("[red]Error: Enter 'y' or 'n'.[/red]")

        if again == "n":
            print("Goodbye!")
            break

if __name__ == "__main__":
    run_simulation()
